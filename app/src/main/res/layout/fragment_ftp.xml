<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="viewModel"
            type="com.erman.usurf.ftp.ui.FTPViewModel" />

        <variable
            name="uiState"
            type="com.erman.usurf.ftp.ui.FtpUiState" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            tools:context=".ftp.ui.FTPFragment">

            <TextView
                android:id="@+id/textView15"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_4"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:layout_marginRight="@dimen/horizontal_margin_4"
                android:text="@string/wifi_status"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/statusTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_8"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:layout_marginRight="@dimen/horizontal_margin_8"
                android:text="@{uiState.isConnectedToWifi ? @string/connected : @string/no_connection}"
                android:textColor="@{uiState.isConnectedToWifi ? @android:color/holo_green_dark : @android:color/holo_red_dark}"
                android:textSize="@dimen/text_size_16" />

            <TextView
                android:id="@+id/textView7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_4"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:layout_marginRight="@dimen/horizontal_margin_4"
                android:text="@string/url"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/urlTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_8"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:layout_marginRight="@dimen/horizontal_margin_8"
                android:text="@{uiState.isConnectedToWifi ? uiState.url : @string/empty}"
                android:textSize="@dimen/text_size_16" />

            <TextView
                android:id="@+id/textView6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_4"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:layout_marginRight="@dimen/horizontal_margin_4"
                android:text="@string/username"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editUserNameTextView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_48"
                android:layout_marginLeft="@dimen/horizontal_margin_8"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:layout_marginRight="@dimen/horizontal_margin_8"
                android:ems="10"
                android:enabled="@{!uiState.isServiceRunning}"
                android:hint="@string/hint_username"
                android:importantForAutofill="no"
                android:inputType="textPersonName"
                android:onTextChanged="@{viewModel::onUsernameChanged}"
                android:text="@{uiState.username}"
                android:textSize="@dimen/text_size_16"
                tools:ignore="LabelFor" />

            <TextView
                android:id="@+id/textView14"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_4"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:layout_marginRight="@dimen/horizontal_margin_4"
                android:text="@string/password"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editPasswordTextView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_48"
                android:layout_marginLeft="@dimen/horizontal_margin_8"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:layout_marginRight="@dimen/horizontal_margin_8"
                android:autofillHints=""
                android:ems="10"
                android:enabled="@{!uiState.isServiceRunning}"
                android:hint="@string/hint_password"
                android:inputType="textPassword"
                android:onTextChanged="@{viewModel::onPasswordChanged}"
                android:text="@{uiState.password}"
                android:textSize="@dimen/text_size_16"
                tools:ignore="LabelFor" />

            <TextView
                android:id="@+id/textView13"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_4"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:layout_marginRight="@dimen/horizontal_margin_4"
                android:text="@string/port"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editPortTextView"
                android:layout_width="match_parent"
                android:layout_height="@dimen/height_48"
                android:layout_marginLeft="@dimen/horizontal_margin_8"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:layout_marginRight="@dimen/horizontal_margin_8"
                android:layout_marginBottom="@dimen/vertical_margin_16"
                android:ems="10"
                android:enabled="@{!uiState.isServiceRunning}"
                android:hint="@string/hint_port"
                android:importantForAutofill="no"
                android:inputType="numberDecimal"
                android:onTextChanged="@{viewModel::onPortChanged}"
                android:text="@{uiState.port}"
                android:textSize="@dimen/text_size_16"
                tools:ignore="LabelFor" />

            <RadioGroup
                android:id="@+id/radioButtonGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/layout_margin_8"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:layout_marginBottom="@dimen/vertical_margin_16"
                android:onCheckedChanged="@{(group, checkedId) -> viewModel.onFtpPathSelected(checkedId)}"
                android:visibility="@{uiState.isServiceRunning ? View.GONE : View.VISIBLE}" />

            <Button
                android:id="@+id/connectButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/horizontal_margin_24"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:layout_marginRight="@dimen/horizontal_margin_24"
                android:layout_marginBottom="@dimen/vertical_margin_32"
                android:background="@drawable/button_selectable_background"
                android:contentDescription="@string/connect"
                android:enabled="@{uiState.isConnectedToWifi}"
                android:onClick="@{() -> viewModel.onConnectClicked()}"
                android:text="@{uiState.isServiceRunning ? @string/disconnect : @string/connect}" />

        </LinearLayout>
    </ScrollView>
</layout>