<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <variable
            name="listener"
            type="com.erman.usurf.home.ui.FavoriteItemListener" />

        <variable
            name="favoriteItem"
            type="com.erman.usurf.home.model.FavoriteItem" />
    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        android:background="@drawable/card_favorite_background"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:onClick="@{() -> listener.onFavoriteClick(favoriteItem.path)}"
        android:onLongClick="@{() -> listener.onFavoriteLongClick(favoriteItem.path, favoriteItem.name)}"
        android:orientation="vertical"
        android:padding="@dimen/layout_margin_8">

        <ImageView
            android:id="@+id/favoriteIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginBottom="@dimen/layout_margin_4"
            android:contentDescription="@string/favorite"
            android:src="@drawable/ic_folder"
            android:tint="@color/colorPrimary" />

        <TextView
            android:id="@+id/favorite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@{favoriteItem.name}"
            android:textColor="@color/daynnightTextColor"
            android:textSize="@dimen/text_size_14" />
    </LinearLayout>
</layout>
