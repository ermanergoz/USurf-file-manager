<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

        <import type="android.view.View" />

        <variable
            name="file"
            type="com.erman.usurf.directory.model.FileModel" />
    </data>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/horizontal_margin_24"
            android:paddingTop="@dimen/vertical_margin_16"
            android:paddingEnd="@dimen/horizontal_margin_24"
            android:paddingBottom="@dimen/vertical_margin_16">

            <!-- Name -->
            <TextView
                android:id="@+id/nameLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/name"
                android:textColor="@color/sectionHeaderColor"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/nameTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:text="@{file.nameWithoutExtension}"
                android:textColor="@color/daynnightTextColor"
                android:textSize="@dimen/text_size_14" />

            <!-- Extension (hidden for directories) -->
            <TextView
                android:id="@+id/extensionLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:text="@string/extension"
                android:textColor="@color/sectionHeaderColor"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold"
                android:visibility="@{file.isDirectory ? View.GONE : View.VISIBLE}" />

            <TextView
                android:id="@+id/extensionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:text="@{file.extension}"
                android:textColor="@color/daynnightTextColor"
                android:textSize="@dimen/text_size_14"
                android:visibility="@{file.isDirectory ? View.GONE : View.VISIBLE}" />

            <!-- Path -->
            <TextView
                android:id="@+id/pathLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:text="@string/path"
                android:textColor="@color/sectionHeaderColor"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/pathTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:text="@{file.path}"
                android:textColor="@color/daynnightTextColor"
                android:textSize="@dimen/text_size_14" />

            <!-- Hidden file indicator -->
            <TextView
                android:id="@+id/isHiddenTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:text="@{file.isHidden ? @string/hidden_file : @string/empty}"
                android:textColor="@color/sectionHeaderColor"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold"
                android:visibility="@{file.isHidden ? View.VISIBLE : View.GONE}" />

            <!-- Size -->
            <TextView
                android:id="@+id/sizeLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:text="@string/size"
                android:textColor="@color/sectionHeaderColor"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/sizeTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:text="@{file.size}"
                android:textColor="@color/daynnightTextColor"
                android:textSize="@dimen/text_size_14" />

            <!-- Permission -->
            <TextView
                android:id="@+id/permissionLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:text="@string/permission"
                android:textColor="@color/sectionHeaderColor"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/permissionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:text="@{file.permission.option}"
                android:textColor="@color/daynnightTextColor"
                android:textSize="@dimen/text_size_14" />

            <!-- Last modification date -->
            <TextView
                android:id="@+id/lastModifiedLabelTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_16"
                android:text="@string/last_modification_date"
                android:textColor="@color/sectionHeaderColor"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lastModificationDateTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/vertical_margin_4"
                android:text="@{file.lastModified}"
                android:textColor="@color/daynnightTextColor"
                android:textSize="@dimen/text_size_14" />

        </LinearLayout>

    </ScrollView>
</layout>
